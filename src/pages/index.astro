  <script>
    /* ===== SMOOTH SCROLL ===== */
    function smoothScrollTo(targetEl){
      var targetY=targetEl.getBoundingClientRect().top+window.scrollY;
      var startY=window.scrollY;
      var distance=targetY-startY;
      var duration=Math.min(900,Math.max(400,Math.abs(distance)*0.6));
      var start=null;
      function step(ts){
        if(!start)start=ts;
        var t=Math.min((ts-start)/duration,1);
        var ease=1-Math.pow(1-t,4);
        window.scrollTo(0,startY+distance*ease);
        if(t<1)requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }
    document.querySelectorAll('a[href^="#"]').forEach(function(link){
      link.addEventListener('click',function(e){
        var target=document.querySelector(this.getAttribute('href'));
        if(target){e.preventDefault();smoothScrollTo(target);}
      });
    });

    /* ===== SCROLL PROGRESS ===== */
    var scrollProgressEl=document.getElementById('scrollProgress');
    function updateScrollProgress(){
      var docH=document.documentElement.scrollHeight-window.innerHeight;
      scrollProgressEl.style.width=(docH>0?(window.scrollY/docH)*100:0)+'%';
    }

    /* ===== BACK TO TOP ===== */
    var dockBttGroup=document.getElementById('dockBttGroup');
    var dockBtt=document.getElementById('dockBtt');
    function updateBtt(){
      if(window.scrollY>400){dockBttGroup.classList.add('show');}
      else{dockBttGroup.classList.remove('show');}
    }
    dockBtt.addEventListener('click',function(){smoothScrollTo(document.getElementById('home'));});

    /* ===== COMBINED SCROLL ===== */
    var scrollTicking=false;
    window.addEventListener('scroll',function(){
      if(!scrollTicking){
        requestAnimationFrame(function(){updateScrollProgress();updateBtt();scrollTicking=false;});
        scrollTicking=true;
      }
    },{passive:true});

    /* ===== SCROLL REVEAL ===== */
    (function(){
      document.querySelectorAll('.bento .reveal').forEach(function(el,i){el.style.transitionDelay=(i*0.08)+'s';});
      document.querySelectorAll('.skill-group.reveal').forEach(function(el,i){el.style.transitionDelay=(i*0.08)+'s';});
      var io=new IntersectionObserver(function(entries){
        entries.forEach(function(entry){
          if(entry.isIntersecting){entry.target.classList.add('visible');io.unobserve(entry.target);}
        });
      },{threshold:0.1,rootMargin:'0px 0px -40px 0px'});
      document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
    })();

    /* ===== CURSOR BLINK FADE ===== */
    setTimeout(function(){
      var c=document.querySelector('.cursor');
      if(c){c.style.transition='opacity 1.2s ease';c.style.opacity='0';}
    },4500);

    /* ===== DOCK ACTIVE STATE ===== */
    (function(){
      var sections=document.querySelectorAll('main section[id], footer[id]');
      var links=document.querySelectorAll('.dock-link[href]');
      var io=new IntersectionObserver(function(entries){
        entries.forEach(function(entry){
          if(entry.isIntersecting){
            var id=entry.target.id;
            links.forEach(function(l){l.classList.toggle('active',l.getAttribute('href')==='#'+id);});
          }
        });
      },{threshold:0.3});
      sections.forEach(function(s){io.observe(s);});
    })();

    /* ===== THEME TOGGLE ===== */
    (function(){
      var html=document.documentElement;
      var btn=document.getElementById('dockTheme');
      var iconSun=document.getElementById('iconSun');
      var iconMoon=document.getElementById('iconMoon');
      var saved=localStorage.getItem('theme');
      if(saved==='light'){html.setAttribute('data-theme','light');}
      updateIcons();
      function updateIcons(){
        var isDark=html.getAttribute('data-theme')!=='light';
        iconSun.style.display=isDark?'block':'none';
        iconMoon.style.display=isDark?'none':'block';
      }
      btn.addEventListener('click',function(e){
        e.stopPropagation();
        var isLight=html.getAttribute('data-theme')==='light';
        html.setAttribute('data-theme',isLight?'dark':'light');
        localStorage.setItem('theme',isLight?'dark':'light');
        updateIcons();
      });
    })();

    /* ===== MUSIC PLAYER ===== */
    (function(){
      var dockMusic=document.getElementById('dockMusic');
      var panel=document.getElementById('musicPanel');
      var panelTrack=document.getElementById('panelTrack');
      var panelArtist=document.getElementById('panelArtist');
      var panelProgressWrap=document.getElementById('panelProgressWrap');
      var panelProgressBar=document.getElementById('panelProgressBar');
      var panelTimeCurrent=document.getElementById('panelTimeCurrent');
      var panelTimeDuration=document.getElementById('panelTimeDuration');
      var playBtn=document.getElementById('musicPlayBtn');
      var iconPlay=document.getElementById('iconPlay');
      var iconPause=document.getElementById('iconPause');
      var visBars=document.querySelectorAll('.vis-mini-bar');
      var audio=new Audio();
      var isPlaying=false;
      var panelOpen=false;
      function formatTime(s){
        if(isNaN(s))return'0:00';
        var m=Math.floor(s/60);
        var sec=Math.floor(s%60);
        return m+':'+(sec<10?'0':'')+sec;
      }
      function updatePlayIcon(){
        iconPlay.style.display=isPlaying?'none':'block';
        iconPause.style.display=isPlaying?'block':'none';
      }
      function play(){
        audio.play().then(function(){
          isPlaying=true;visBars.forEach(function(b){b.classList.add('on');});updatePlayIcon();
        }).catch(function(){
          isPlaying=false;visBars.forEach(function(b){b.classList.remove('on');});updatePlayIcon();
        });
      }
      function pause(){
        audio.pause();isPlaying=false;visBars.forEach(function(b){b.classList.remove('on');});updatePlayIcon();
      }
      panelTrack.textContent='Inspiring Technology';
      panelArtist.textContent='FRUITYAUDIO';
      audio.src='/soundtrack.mp3';
      audio.preload='metadata';
      audio.load();
      dockMusic.addEventListener('click',function(e){
        e.stopPropagation();panelOpen=!panelOpen;panel.classList.toggle('open',panelOpen);
      });
      playBtn.addEventListener('click',function(){if(isPlaying){pause();}else{play();}});
      document.addEventListener('click',function(e){
        if(panelOpen&&!document.getElementById('dockWrap').contains(e.target)){panelOpen=false;panel.classList.remove('open');}
      });
      panel.addEventListener('click',function(e){e.stopPropagation();});
      audio.addEventListener('timeupdate',function(){
        if(audio.duration){panelProgressBar.style.width=(audio.currentTime/audio.duration*100)+'%';panelTimeCurrent.textContent=formatTime(audio.currentTime);}
      });
      audio.addEventListener('loadedmetadata',function(){panelTimeDuration.textContent=formatTime(audio.duration);});
      audio.addEventListener('ended',function(){audio.currentTime=0;pause();});
      audio.addEventListener('error',function(){
        panelTrack.textContent='File not found';
        panelArtist.textContent='Put soundtrack.mp3 in /public';
        isPlaying=false;updatePlayIcon();
      });
      panelProgressWrap.addEventListener('click',function(e){
        if(!audio.duration)return;
        var r=panelProgressWrap.getBoundingClientRect();
        audio.currentTime=Math.max(0,Math.min(1,(e.clientX-r.left)/r.width))*audio.duration;
      });
    })();

    /* ===== PARALLAX ORBS ===== */
    (function(){
      var orbs=document.querySelectorAll('.orb');var t=false;
      window.addEventListener('scroll',function(){
        if(!t){requestAnimationFrame(function(){
          var y=window.scrollY;
          orbs.forEach(function(o,i){
            var s=i===0?0.15:0.25;
            o.style.transform='translateX(-50%) translateY('+(y*s)+'px)';
          });t=false;
        });t=true;}
      },{passive:true});
    })();
  </script>
